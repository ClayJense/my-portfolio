# =============================================================================
# Portfolio — Variables d'environnement
# =============================================================================
# Copie ce fichier en .env.local et remplis les valeurs.
# Ne commite jamais .env.local (il est ignoré par git).
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase (contact, stockage)
# -----------------------------------------------------------------------------
# URL du projet : Dashboard Supabase → Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Clé anonyme (publique) : Dashboard → Settings → API → anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Clé service_role (côté serveur uniquement, jamais exposée au client)
# Utilisée pour les API routes qui écrivent en base (contact, etc.)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# -----------------------------------------------------------------------------
# Mailtrap (envoi d’emails — formulaire de contact)
# -----------------------------------------------------------------------------
# Token API : Mailtrap → Settings → API Tokens → Generate
MAILTRAP_API_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Email expéditeur affiché (doit être vérifié dans Mailtrap / domaine)
MAILTRAP_FROM_EMAIL=izayidali@biacode.tech
MAILTRAP_FROM_NAME=Portfolio Iza

# Email qui reçoit les messages du formulaire de contact
CONTACT_TO_EMAIL=izayidali@biacode.tech

# -----------------------------------------------------------------------------
# Chatbot (optionnel — si tu branches une API type OpenAI plus tard)
# -----------------------------------------------------------------------------
# Exemple pour un bot IA (à décommenter si tu l’utilises)
# OPENAI_API_KEY=sk-...
