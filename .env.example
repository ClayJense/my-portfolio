# =============================================================================
# Portfolio — Variables d'environnement
# =============================================================================
# Copie ce fichier en .env.local et remplis les valeurs.
# Ne commite jamais .env.local (il est ignoré par git).
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase (contact, stockage)
# -----------------------------------------------------------------------------
# URL du projet : Dashboard Supabase → Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Clé anonyme (publique) : Dashboard → Settings → API → anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Clé service_role (côté serveur uniquement, jamais exposée au client)
# Utilisée pour les API routes qui écrivent en base (contact, etc.)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# -----------------------------------------------------------------------------
# Mailtrap (envoi d’emails — formulaire de contact)
# -----------------------------------------------------------------------------
# Token API : Mailtrap → Settings → API Tokens → Generate
MAILTRAP_API_TOKEN=

# SMTP (prioritaire si les 4 sont renseignés). IMPORTANT : avec Sandbox les mails n'arrivent PAS dans ta boîte LWS, seulement dans Mailtrap → Email Testing → Inbox. Pour recevoir chez toi : utilise Live (live.smtp.mailtrap.io, user=api, pass=API token).
MAILTRAP_SMTP_HOST=sandbox.smtp.mailtrap.io
MAILTRAP_SMTP_PORT=587
MAILTRAP_SMTP_USER=
MAILTRAP_SMTP_PASS=

# Expéditeur affiché dans le mail (peut être le même que CONTACT_TO_EMAIL, ce n'est pas un problème)
MAILTRAP_FROM_EMAIL=izayidali@biacode.tech
MAILTRAP_FROM_NAME=Portfolio Iza

# Adresse qui reçoit les messages du formulaire (où tu veux recevoir les demandes)
CONTACT_TO_EMAIL=izayidali@biacode.tech

# -----------------------------------------------------------------------------
# reCAPTCHA v2 (case « Je ne suis pas un robot » — formulaire Contact)
# -----------------------------------------------------------------------------
# Clé du site (publique) : Google Admin reCAPTCHA → reCAPTCHA v2 → Clés
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
# Clé secrète (serveur uniquement, jamais dans le code client)
RECAPTCHA_SECRET_KEY=

# -----------------------------------------------------------------------------
# Chatbot (Mistral)
# -----------------------------------------------------------------------------
# Clé API Mistral (à décommenter si tu l’utilises)
MISTRAL_API_KEY=
# MISTRAL_API_URL=https://api.mistral.ai/v1/chat/completions
# MISTRAL_MODEL=mistral-small-latest
